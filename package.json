{
  "name": "skill-studio-pro",
  "private": true,
  "version": "0.1.0-beta.1",
  "license": "Apache-2.0",
  "description": "Skill Studio Pro local-first desktop workspace for AI Agent Skill assets",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hao2080/skill-studio-pro.git"
  },
  "homepage": "https://github.com/Hao2080/skill-studio-pro#readme",
  "bugs": {
    "url": "https://github.com/Hao2080/skill-studio-pro/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "sbom:generate": "node scripts/generate-supply-chain.mjs",
    "sbom:check": "node scripts/generate-supply-chain.mjs --check",
    "release:metadata": "node scripts/verify-release-metadata.mjs",
    "supply-chain:check": "npm run sbom:check && npm run release:metadata",
    "security:repo": "node scripts/verify-repository-hygiene.mjs",
    "check": "npm run typecheck && npm run test && npm run build && npm run rust:fmt && npm run rust:check && npm run rust:clippy && npm run rust:test && npm run security:repo"
  },
  "dependencies": {
    "@lobehub/icons-static-svg": "^1.87.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "antd": "^6.5.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "simple-icons": "^16.17.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.3"
  }
}
