# ===========================================
# Skill Studio Pro - Open Source .gitignore
# ===========================================

# ========== Node ==========
node_modules/

# ========== Build Output ==========
dist/
build/
target/
src-tauri/target/
*.AppImage
*.dmg
*.msi
*.exe
*.deb
*.rpm

# ========== OS ==========
.DS_Store
Thumbs.db
desktop.ini

# ========== Temp Files ==========
*.tmp
*.bak
*.log
logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.tmp/
release/
releases/

# ========== Secrets & Credentials ==========
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.secret
*.secrets
secrets*.json
credentials*.json
.npmrc

# ========== Local Application Data ==========
/.skill-studio-pro/
/.skill-studio/
/metadata.db*
/settings.local.json
/workspace.local.json
/trash/
/recycle-bin/
/.trash/
/staging/
/cache/

# ========== Local Skills & Agent Data ==========
/skills/
/local-skills/
/user-skills/
/.codex/
/.claude/
/.cursor/
/.windsurf/
/.gemini/

# ========== Git Internals ==========
.worktrees/

# ========== Claude Code Session Data ==========
.claude/
.superpowers/

# ========== gstack Browser Data ==========
.gstack/
.gstack-preview/

# ========== Editor & IDE ==========
.vscode/launch.json
.vscode/tasks.json

# ===========================================
# Files tracked in git that should NOT be
# committed to the open source repository.
# Remove them with:
#   git rm -r --cached <path>
# ===========================================

# Personal development notes and working logs
docs_idea/

# Private project plans and internal documentation
docs_self/

# Logo source artwork (keep the generated icons instead)
branding/logo-source.png

# Build-generated schema files
src-tauri/gen/schemas/*.json

# Development-only logo generation scripts
scripts/generate-app-icon-previews.py
scripts/generate-horizontal-logo.ps1
scripts/prepare-logo-master.py
